{
  "name": "inventory-management-system",
  "version": "1.0.0",
  "description": "Smart Inventory & Billing System - Frontend + Backend",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd frontend && npm run dev",
    "server": "cd backend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:exe": "npm run build:frontend && electron-builder",
    "build:mac": "npm run build:frontend && electron-builder --mac",
    "electron:start": "npm run build:frontend && electron .",
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install"
  },
  "build": {
    "appId": "com.inventory.billing.system",
    "productName": "Inventory & Billing OS",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "backend/build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "inventory",
    "billing",
    "management",
    "envelope"
  ],
  "author": "Your Name",
  "license": "MIT"
}
